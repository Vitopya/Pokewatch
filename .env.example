# AI provider API keys — server-side only, never exposed to the browser.
# Configure the one matching your active provider in Gazette settings.

# Gemini (default). Free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override default model
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic (optional)
# ANTHROPIC_API_KEY=

# OpenAI (optional)
# OPENAI_API_KEY=
